{
  "scripts": {
    "build": "node -e \"const fs=require('fs');fs.writeFileSync('viz-codelab.js',fs.readFileSync('dscc.min.js','utf8')+'\\n'+fs.readFileSync('viz-codelab-src.js','utf8'))\"",
    "watch": "node -e \"const fs=require('fs'),build=()=>fs.writeFileSync('viz-codelab.js',fs.readFileSync('dscc.min.js','utf8')+'\\n'+fs.readFileSync('viz-codelab-src.js','utf8'));build();fs.watch('viz-codelab-src.js',build)\""
  },
  "dependencies": {
    "@google/dscc": "^0.3.22"
  }
}
